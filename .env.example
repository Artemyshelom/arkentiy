# ============================================================
# Ёбидоёби — Интеграции: шаблон переменных окружения
# Скопировать в .env и заполнить реальными значениями
# .env НИКОГДА не коммитить в git!
# ============================================================

# --- iiko ---
IIKO_API_KEY=your_iiko_api_key_here
# JSON словарь: {"Абакан": "uuid", "Барнаул": "uuid", "Томск": "uuid", "Черногорск": "uuid"}
# Взять из ответа POST /api/1/organizations
IIKO_ORG_IDS={"Абакан": "", "Барнаул": "", "Томск": "", "Черногорск": ""}

# --- Telegram ---
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# chat_id для каждого чата (отрицательное число для групп)
TELEGRAM_CHAT_ALERTS=-1001234567890
TELEGRAM_CHAT_REPORTS=-1001234567891
TELEGRAM_CHAT_MEETINGS=-1001234567892
TELEGRAM_CHAT_MONITORING=-1001234567893

# --- Google (Service Account) ---
# Путь к JSON-ключу сервисного аккаунта внутри контейнера
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json
# ID таблицы Google Sheets для выгрузки из iiko
GOOGLE_SHEETS_IIKO_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
# Папка Google Drive для бэкапов SQLite
GOOGLE_DRIVE_BACKUP_FOLDER_ID=your_google_drive_folder_id

# --- MyMeet.ai ---
MYMEET_API_KEY=your_mymeet_api_key_here

# --- Битрикс24 ---
# Входящий вебхук (для вызова REST API из скриптов)
BITRIX24_INCOMING_WEBHOOK=https://your-domain.bitrix24.ru/rest/1/abcdefghijk/

# --- ЮKassa ---
YUKASSA_SHOP_ID=your_shop_id
YUKASSA_SECRET_KEY=your_secret_key
YUKASSA_RETURN_URL=https://arkentiy.ru

# --- Безопасность ---
# Секрет для валидации входящих webhooks (openssl rand -hex 16)
WEBHOOK_SECRET=change_me_to_random_32_char_string
# JWT-секрет для веб-кабинета (openssl rand -hex 32)
JWT_SECRET=change_me_to_random_64_char_string
# Режим отладки (включает demo-логин art@ebidoebi.ru / demo123)
DEBUG=false

# --- Приложение ---
# Часовой пояс (для расписания — все города в разных TZ, используем Москву как базу)
TZ=Europe/Moscow
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Путь к SQLite базе
DATABASE_URL=sqlite+aiosqlite:////app/data/app.db
